{
  "name": "jzoom-operating-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Production foundation for the Jzoom Operating Platform.",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.13.0 <25",
    "pnpm": ">=11.0.0 <12"
  },
  "scripts": {
    "build": "corepack pnpm --workspace-concurrency=1 -r --if-present build",
    "dev": "corepack pnpm --parallel --filter @jzoom/web --filter @jzoom/api --filter @jzoom/worker dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "corepack pnpm --workspace-concurrency=1 -r --if-present lint",
    "openapi:generate": "corepack pnpm --filter @jzoom/api openapi:generate",
    "prisma:generate": "corepack pnpm --filter @jzoom/database generate",
    "test": "corepack pnpm build && corepack pnpm --workspace-concurrency=1 -r --if-present test",
    "typecheck": "corepack pnpm --workspace-concurrency=1 --filter @jzoom/contracts --filter @jzoom/config --filter @jzoom/database -r build && corepack pnpm --workspace-concurrency=1 -r --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.0.0"
  }
}
