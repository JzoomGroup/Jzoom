NODE_ENV=development

# API
API_PORT=4000
DATABASE_URL=postgresql://jzoom:replace_with_local_password@localhost:5432/jzoom?schema=public
OPENAPI_ENABLED=true

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

# Worker
WORKER_NAME=jzoom-worker

# Docker Compose PostgreSQL
POSTGRES_DB=jzoom
POSTGRES_USER=jzoom
POSTGRES_PASSWORD=replace_with_local_password
