NODE_ENV=development

# API
API_PORT=4000
DATABASE_URL=postgresql://jzoom:replace_with_local_password@localhost:5432/jzoom?schema=public
OPENAPI_ENABLED=true
WEB_ORIGIN=http://localhost:3000
AUTH_SESSION_TTL_MINUTES=480
AUTH_COOKIE_NAME=jzoom_session
AUTH_CSRF_COOKIE_NAME=jzoom_csrf
# Set to a parent domain in production when web/API run on sibling subdomains.
# Example: AUTH_COOKIE_DOMAIN=.example.com
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_EXPOSE_TEST_TOKENS=false
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# Optional, one-time bootstrap. Provide both values only when running the
# bootstrap command, then remove them from the environment.
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=replace_with_a_unique_12_plus_character_password

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_AUTH_CSRF_COOKIE_NAME=jzoom_csrf

# Worker
WORKER_NAME=jzoom-worker

# Docker Compose PostgreSQL
POSTGRES_DB=jzoom
POSTGRES_USER=jzoom
POSTGRES_PASSWORD=replace_with_local_password
