generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RecordStatus {
  DRAFT
  ACTIVE
  DISABLED
  ARCHIVED
}

enum RevisionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum BlueprintImportStatus {
  PENDING
  VALIDATED
  APPLIED
  APPLIED_WITH_WARNINGS
  FAILED
}

enum BlueprintIssueSeverity {
  INFO
  WARNING
  ERROR
}

enum UserType {
  INTERNAL
  EXTERNAL
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
  ARCHIVED
}

enum AuthTokenType {
  PASSWORD_RESET
  INVITATION
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum DataScopeType {
  OWN_CLIENT
  ASSIGNED_CLIENTS
  ASSIGNED_WORK
  TEAM_DOMAIN
  GLOBAL
}

enum WorkflowType {
  REQUEST
  PROJECT
}

enum QuoteStatus {
  DRAFT
  CALCULATED
  NEEDS_APPROVAL
  ISSUED
  APPROVED
  EXPIRED
  CANCELLED
  ACTIVATED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  VOID
}

enum SubscriptionStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  EXPIRED
  CANCELLED
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  CLIENT_REVIEW
  COMPLETED
  CLOSED
  ARCHIVED
}

enum OutputStatus {
  DRAFT
  INTERNAL_REVIEW
  APPROVED_INTERNAL
  SHARED
  REVISION_REQUESTED
  APPROVED
  LOCKED
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REVERSED
}

enum LedgerTransactionType {
  CREDIT
  DEBIT
  REVERSAL
  ADJUSTMENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  RETURNED
  REJECTED
  CANCELLED
}

enum FileVisibility {
  INTERNAL
  CLIENT_VISIBLE
}

enum NotificationStatus {
  PENDING
  DELIVERED
  FAILED
  CANCELLED
}

enum JobStatus {
  PENDING
  VALIDATING
  READY
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum AuditSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  SECRET_REFERENCE
}

enum TranslationRevisionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model BlueprintImport {
  id                   String                        @id @default(uuid()) @db.Uuid
  blueprintCode        String
  version              String
  sourceFileName       String
  sha256               String                        @unique
  manifest             Json
  status               BlueprintImportStatus         @default(PENDING)
  warningCount         Int                           @default(0)
  errorCount           Int                           @default(0)
  importedAt           DateTime                      @default(now())
  appliedAt            DateTime?
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  sheetSnapshots       BlueprintSheetSnapshot[]
  issues               BlueprintIssue[]
  monthlyRevisions     MonthlyServiceRevision[]
  itemRevisions        ServiceItemRevision[]
  oneTimeRevisions     OneTimeServiceRevision[]
  pricingRevisions     PricingRuleRevision[]
  workflowVersions     WorkflowVersion[]
  pdfVersions          PdfTemplateVersion[]
  notificationVersions NotificationTemplateVersion[]
  validationRevisions  ValidationRuleRevision[]
  settingRevisions     PlatformSettingRevision[]
  translationRevisions TranslationRevision[]

  @@unique([blueprintCode, version, sha256])
  @@map("blueprint_imports")
}

model BlueprintSheetSnapshot {
  id                String          @id @default(uuid()) @db.Uuid
  blueprintImportId String          @db.Uuid
  sheetName         String
  tableName         String?
  rowCount          Int
  headers           Json
  rows              Json
  sha256            String
  createdAt         DateTime        @default(now())
  blueprintImport   BlueprintImport @relation(fields: [blueprintImportId], references: [id], onDelete: Cascade)

  @@unique([blueprintImportId, sheetName])
  @@index([sheetName])
  @@map("blueprint_sheet_snapshots")
}

model BlueprintIssue {
  id                String                 @id @default(uuid()) @db.Uuid
  blueprintImportId String                 @db.Uuid
  severity          BlueprintIssueSeverity
  code              String
  sheetName         String?
  rowReference      String?
  entityCode        String?
  message           String                 @db.Text
  normalizedDefault Json?
  createdAt         DateTime               @default(now())
  blueprintImport   BlueprintImport        @relation(fields: [blueprintImportId], references: [id], onDelete: Cascade)

  @@index([blueprintImportId, severity])
  @@map("blueprint_issues")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @unique
  name            String
  nameAr          String?
  nameEn          String?
  userType        UserType
  description     String?          @db.Text
  dataScope       String?          @db.Text
  capabilities    String?          @db.Text
  restrictions    String?          @db.Text
  isSystem        Boolean          @default(false)
  status          RecordStatus     @default(ACTIVE)
  sortOrder       Int              @default(0)
  archivedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([status, sortOrder])
  @@map("roles")
}

model Permission {
  id              String                   @id @default(uuid()) @db.Uuid
  code            String                   @unique
  name            String
  module          String
  action          String
  description     String?                  @db.Text
  status          RecordStatus             @default(ACTIVE)
  sortOrder       Int                      @default(0)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  rolePermissions RolePermission[]
  userOverrides   UserPermissionOverride[]

  @@index([module, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String           @db.Uuid
  permissionId String           @db.Uuid
  effect       PermissionEffect @default(ALLOW)
  scopeRule    String?
  constraints  Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  role         Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id                  String                   @id @default(uuid()) @db.Uuid
  email               String                   @unique
  passwordHash        String?
  displayName         String
  preferredLocale     String                   @default("ar")
  userType            UserType
  status              UserStatus               @default(INVITED)
  failedLoginCount    Int                      @default(0)
  lockedUntil         DateTime?
  passwordChangedAt   DateTime?
  sessionVersion      Int                      @default(1)
  lastLoginAt         DateTime?
  archivedAt          DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  roles               UserRole[]
  permissionOverrides UserPermissionOverride[]
  scopes              UserScope[]
  clientAssignments   ClientAssignment[]
  comments            Comment[]
  internalNotes       InternalNote[]
  uploadedFiles       FileMetadata[]
  timeEntries         TimeEntry[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  authSessions        AuthSession[]
  authTokens          AuthToken[]              @relation("AuthTokenUser")
  createdAuthTokens   AuthToken[]              @relation("AuthTokenCreator")

  @@index([status])
  @@index([lockedUntil])
  @@map("users")
}

model AuthSession {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  tokenHash     String    @unique
  csrfTokenHash String
  sessionVersion Int
  expiresAt     DateTime
  lastSeenAt    DateTime  @default(now())
  revokedAt     DateTime?
  revokeReason  String?
  ipAddress     String?
  userAgent     String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model AuthToken {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @db.Uuid
  type        AuthTokenType
  tokenHash   String        @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  createdById String?       @db.Uuid
  createdAt   DateTime      @default(now())
  user        User          @relation("AuthTokenUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy   User?         @relation("AuthTokenCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([userId, type, consumedAt, expiresAt])
  @@index([createdById])
  @@map("auth_tokens")
}

model UserRole {
  userId    String   @db.Uuid
  roleId    String   @db.Uuid
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model UserPermissionOverride {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @db.Uuid
  permissionId String           @db.Uuid
  effect       PermissionEffect
  scopeRule    String?
  reason       String           @db.Text
  expiresAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permission_overrides")
}

model UserScope {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String        @db.Uuid
  scopeType DataScopeType
  clientId  String?       @db.Uuid
  domain    String?
  teamCode  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client?       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId, scopeType])
  @@index([clientId])
  @@map("user_scopes")
}

model Client {
  id                     String                  @id @default(uuid()) @db.Uuid
  code                   String                  @unique
  name                   String
  legalName              String?
  commercialRegistration String?
  sector                 String
  city                   String?
  employeesCount         Int                     @default(0)
  branchesCount          Int                     @default(0)
  transactionVolume      String?
  operationalComplexity  String?
  dataReadiness          String?
  urgency                String?
  billingContact         String?
  authorizedApprover     String
  status                 RecordStatus            @default(ACTIVE)
  archivedAt             DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  contacts               ClientContact[]
  assignments            ClientAssignment[]
  scopes                 UserScope[]
  subscriptions          Subscription[]
  quotes                 Quote[]
  invoices               Invoice[]
  requests               Request[]
  projects               Project[]
  hourTransactions       HourLedgerTransaction[]

  @@index([status])
  @@index([sector])
  @@map("clients")
}

model ClientContact {
  id        String       @id @default(uuid()) @db.Uuid
  clientId  String       @db.Uuid
  name      String
  email     String?
  phone     String?
  role      String?
  isPrimary Boolean      @default(false)
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, email])
  @@index([clientId, status])
  @@map("client_contacts")
}

model ClientAssignment {
  id        String    @id @default(uuid()) @db.Uuid
  clientId  String    @db.Uuid
  userId    String    @db.Uuid
  roleCode  String
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([clientId, userId, roleCode, startsAt])
  @@index([userId, startsAt, endsAt])
  @@map("client_assignments")
}

model ServiceLevel {
  id                   String                      @id @default(uuid()) @db.Uuid
  code                 String                      @unique
  labelAr              String
  labelEn              String?
  purpose              String?                     @db.Text
  hoursSource          String?
  slaRule              String?                     @db.Text
  scopeRule            String?                     @db.Text
  governanceRule       String?                     @db.Text
  isCustom             Boolean                     @default(false)
  status               RecordStatus                @default(ACTIVE)
  sortOrder            Int                         @default(0)
  archivedAt           DateTime?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  monthlyConfigs       MonthlyServiceLevelConfig[]
  itemInclusions       ServiceItemLevelInclusion[]
  subscriptionServices SubscriptionService[]

  @@index([status, sortOrder])
  @@map("service_levels")
}

model MonthlyService {
  id         String                   @id @default(uuid()) @db.Uuid
  code       String                   @unique
  externalId String?
  status     RecordStatus             @default(ACTIVE)
  sortOrder  Int                      @default(0)
  archivedAt DateTime?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  revisions  MonthlyServiceRevision[]
  items      ServiceItem[]

  @@index([status, sortOrder])
  @@map("monthly_services")
}

model MonthlyServiceRevision {
  id                      String                      @id @default(uuid()) @db.Uuid
  monthlyServiceId        String                      @db.Uuid
  sourceBlueprintImportId String?                     @db.Uuid
  version                 Int
  status                  RevisionStatus              @default(DRAFT)
  effectiveFrom           DateTime?
  effectiveTo             DateTime?
  nameAr                  String
  nameEn                  String
  paymentType             String                      @default("Monthly")
  serviceLine             String                      @default("Operate")
  domain                  String
  description             String                      @db.Text
  visibleInPricing        Boolean                     @default(true)
  sellingHourlyRateSar    Decimal                     @db.Decimal(18, 2)
  internalHourlyCostSar   Decimal                     @db.Decimal(18, 2)
  setupFeePct             Decimal                     @db.Decimal(7, 4)
  defaultSlaHours         Int
  deductHours             Boolean                     @default(true)
  requiresSupervisor      Boolean                     @default(false)
  requiresManagement      Boolean                     @default(false)
  clientApprovalRequired  Boolean                     @default(false)
  cardConfiguration       Json?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  monthlyService          MonthlyService              @relation(fields: [monthlyServiceId], references: [id], onDelete: Cascade)
  sourceBlueprintImport   BlueprintImport?            @relation(fields: [sourceBlueprintImportId], references: [id], onDelete: SetNull)
  levelConfigs            MonthlyServiceLevelConfig[]
  subscriptionServices    SubscriptionService[]
  quoteItems              QuoteItem[]

  @@unique([monthlyServiceId, version])
  @@index([monthlyServiceId, status, effectiveFrom])
  @@map("monthly_service_revisions")
}

model MonthlyServiceLevelConfig {
  id                       String                 @id @default(uuid()) @db.Uuid
  monthlyServiceRevisionId String                 @db.Uuid
  serviceLevelId           String                 @db.Uuid
  hours                    Decimal                @db.Decimal(10, 2)
  slaHours                 Int?
  priorityRule             String?
  isEnabled                Boolean                @default(true)
  sortOrder                Int                    @default(0)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  monthlyServiceRevision   MonthlyServiceRevision @relation(fields: [monthlyServiceRevisionId], references: [id], onDelete: Cascade)
  serviceLevel             ServiceLevel           @relation(fields: [serviceLevelId], references: [id], onDelete: Restrict)

  @@unique([monthlyServiceRevisionId, serviceLevelId])
  @@map("monthly_service_level_configs")
}

model ServiceItem {
  id               String                @id @default(uuid()) @db.Uuid
  code             String                @unique
  monthlyServiceId String                @db.Uuid
  status           RecordStatus          @default(ACTIVE)
  sortOrder        Int                   @default(0)
  archivedAt       DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  monthlyService   MonthlyService        @relation(fields: [monthlyServiceId], references: [id], onDelete: Restrict)
  revisions        ServiceItemRevision[]

  @@index([monthlyServiceId, status, sortOrder])
  @@map("service_items")
}

model ServiceItemRevision {
  id                      String                         @id @default(uuid()) @db.Uuid
  serviceItemId           String                         @db.Uuid
  sourceBlueprintImportId String?                        @db.Uuid
  version                 Int
  status                  RevisionStatus                 @default(DRAFT)
  effectiveFrom           DateTime?
  effectiveTo             DateTime?
  nameAr                  String
  nameEn                  String
  expectedOutput          String?                        @db.Text
  visibleInQuote          Boolean                        @default(true)
  requiresFile            Boolean                        @default(false)
  deductHours             Boolean                        @default(true)
  requestType             String?
  createdAt               DateTime                       @default(now())
  updatedAt               DateTime                       @updatedAt
  serviceItem             ServiceItem                    @relation(fields: [serviceItemId], references: [id], onDelete: Cascade)
  sourceBlueprintImport   BlueprintImport?               @relation(fields: [sourceBlueprintImportId], references: [id], onDelete: SetNull)
  levelInclusions         ServiceItemLevelInclusion[]
  quoteSnapshots          QuoteItemServiceItemSnapshot[]
  requests                Request[]

  @@unique([serviceItemId, version])
  @@index([serviceItemId, status, effectiveFrom])
  @@map("service_item_revisions")
}

model ServiceItemLevelInclusion {
  serviceItemRevisionId String              @db.Uuid
  serviceLevelId        String              @db.Uuid
  included              Boolean             @default(true)
  sortOrder             Int                 @default(0)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  serviceItemRevision   ServiceItemRevision @relation(fields: [serviceItemRevisionId], references: [id], onDelete: Cascade)
  serviceLevel          ServiceLevel        @relation(fields: [serviceLevelId], references: [id], onDelete: Restrict)

  @@id([serviceItemRevisionId, serviceLevelId])
  @@index([serviceLevelId, included])
  @@map("service_item_level_inclusions")
}

model OneTimeService {
  id          String                   @id @default(uuid()) @db.Uuid
  code        String                   @unique
  serviceLine String
  status      RecordStatus             @default(ACTIVE)
  sortOrder   Int                      @default(0)
  archivedAt  DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  revisions   OneTimeServiceRevision[]

  @@index([serviceLine, status, sortOrder])
  @@map("one_time_services")
}

model OneTimeServiceRevision {
  id                      String                      @id @default(uuid()) @db.Uuid
  oneTimeServiceId        String                      @db.Uuid
  sourceBlueprintImportId String?                     @db.Uuid
  version                 Int
  status                  RevisionStatus              @default(DRAFT)
  effectiveFrom           DateTime?
  effectiveTo             DateTime?
  nameAr                  String
  nameEn                  String
  paymentType             String                      @default("One-Time")
  basePriceSar            Decimal                     @db.Decimal(18, 2)
  estimatedHours          Decimal                     @db.Decimal(10, 2)
  durationDays            Int
  visibleInPricing        Boolean                     @default(true)
  createsProject          Boolean                     @default(true)
  description             String                      @db.Text
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  oneTimeService          OneTimeService              @relation(fields: [oneTimeServiceId], references: [id], onDelete: Cascade)
  sourceBlueprintImport   BlueprintImport?            @relation(fields: [sourceBlueprintImportId], references: [id], onDelete: SetNull)
  phases                  OneTimeServicePhase[]
  deliverables            OneTimeServiceDeliverable[]
  quoteItems              QuoteItem[]
  projects                Project[]

  @@unique([oneTimeServiceId, version])
  @@index([oneTimeServiceId, status, effectiveFrom])
  @@map("one_time_service_revisions")
}

model OneTimeServicePhase {
  id                       String                 @id @default(uuid()) @db.Uuid
  oneTimeServiceRevisionId String                 @db.Uuid
  code                     String
  nameAr                   String?
  nameEn                   String
  description              String?                @db.Text
  sortOrder                Int
  isRequired               Boolean                @default(true)
  status                   RecordStatus           @default(ACTIVE)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  oneTimeServiceRevision   OneTimeServiceRevision @relation(fields: [oneTimeServiceRevisionId], references: [id], onDelete: Cascade)

  @@unique([oneTimeServiceRevisionId, code])
  @@index([oneTimeServiceRevisionId, sortOrder])
  @@map("one_time_service_phases")
}

model OneTimeServiceDeliverable {
  id                       String                 @id @default(uuid()) @db.Uuid
  oneTimeServiceRevisionId String                 @db.Uuid
  code                     String
  nameAr                   String?
  nameEn                   String
  description              String?                @db.Text
  sortOrder                Int
  isRequired               Boolean                @default(true)
  requiresClientApproval   Boolean                @default(true)
  status                   RecordStatus           @default(ACTIVE)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  oneTimeServiceRevision   OneTimeServiceRevision @relation(fields: [oneTimeServiceRevisionId], references: [id], onDelete: Cascade)

  @@unique([oneTimeServiceRevisionId, code])
  @@index([oneTimeServiceRevisionId, sortOrder])
  @@map("one_time_service_deliverables")
}

model PricingRule {
  id         String                @id @default(uuid()) @db.Uuid
  code       String                @unique
  name       String
  status     RecordStatus          @default(ACTIVE)
  sortOrder  Int                   @default(0)
  archivedAt DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  revisions  PricingRuleRevision[]

  @@index([status, sortOrder])
  @@map("pricing_rules")
}

model PricingRuleRevision {
  id                      String           @id @default(uuid()) @db.Uuid
  pricingRuleId           String           @db.Uuid
  sourceBlueprintImportId String?          @db.Uuid
  version                 Int
  status                  RevisionStatus   @default(DRAFT)
  effectiveFrom           DateTime?
  effectiveTo             DateTime?
  formulaOrRule           String           @db.Text
  appliesTo               String
  implementationOwner     String?
  visibility              String?          @db.Text
  configuration           Json?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  pricingRule             PricingRule      @relation(fields: [pricingRuleId], references: [id], onDelete: Cascade)
  sourceBlueprintImport   BlueprintImport? @relation(fields: [sourceBlueprintImportId], references: [id], onDelete: SetNull)

  @@unique([pricingRuleId, version])
  @@index([pricingRuleId, status, effectiveFrom])
  @@map("pricing_rule_revisions")
}

model ValidationRule {
  id         String                   @id @default(uuid()) @db.Uuid
  code       String                   @unique
  entity     String
  field      String
  status     RecordStatus             @default(ACTIVE)
  sortOrder  Int                      @default(0)
  archivedAt DateTime?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  revisions  ValidationRuleRevision[]

  @@index([entity, field, status])
  @@map("validation_rules")
}

model ValidationRuleRevision {
  id                      String           @id @default(uuid()) @db.Uuid
  validationRuleId        String           @db.Uuid
  sourceBlueprintImportId String?          @db.Uuid
  version                 Int
  status                  RevisionStatus   @default(DRAFT)
  effectiveFrom           DateTime?
  effectiveTo             DateTime?
  rule                    String           @db.Text
  errorMessageAr          String?
  errorMessageEn          String?
  enforcedIn              String
  failureBehavior         String           @db.Text
  configuration           Json?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  validationRule          ValidationRule   @relation(fields: [validationRuleId], references: [id], onDelete: Cascade)
  sourceBlueprintImport   BlueprintImport? @relation(fields: [sourceBlueprintImportId], references: [id], onDelete: SetNull)

  @@unique([validationRuleId, version])
  @@index([validationRuleId, status, effectiveFrom])
  @@map("validation_rule_revisions")
}

model WorkflowDefinition {
  id         String            @id @default(uuid()) @db.Uuid
  code       String            @unique
  name       String
  type       WorkflowType
  status     RecordStatus      @default(ACTIVE)
  sortOrder  Int               @default(0)
  archivedAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  versions   WorkflowVersion[]

  @@index([type, status])
  @@map("workflow_definitions")
}

model WorkflowVersion {
  id                      String               @id @default(uuid()) @db.Uuid
  workflowDefinitionId    String               @db.Uuid
  sourceBlueprintImportId String?              @db.Uuid
  version                 Int
  status                  RevisionStatus       @default(DRAFT)
  effectiveFrom           DateTime?
  effectiveTo             DateTime?
  configuration           Json?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  workflowDefinition      WorkflowDefinition   @relation(fields: [workflowDefinitionId], references: [id], onDelete: Cascade)
  sourceBlueprintImport   BlueprintImport?     @relation(fields: [sourceBlueprintImportId], references: [id], onDelete: SetNull)
  states                  WorkflowState[]
  transitions             WorkflowTransition[]
  requests                Request[]
  projects                Project[]
  events                  WorkflowEvent[]

  @@unique([workflowDefinitionId, version])
  @@index([workflowDefinitionId, status, effectiveFrom])
  @@map("workflow_versions")
}

model WorkflowState {
  id                  String               @id @default(uuid()) @db.Uuid
  workflowVersionId   String               @db.Uuid
  code                String
  labelAr             String?
  labelEn             String
  stateType           String?
