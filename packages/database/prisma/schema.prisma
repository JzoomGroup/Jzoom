  output          ProjectOutput? @relation(fields: [outputId], references: [id], onDelete: Cascade)
  uploadedBy      User           @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([requestId, visibility])
  @@index([projectId, visibility])
  @@index([outputId, visibility])
  @@map("files_metadata")
}

model Approval {
  id           String         @id @default(uuid()) @db.Uuid
  requestId    String?        @db.Uuid
  projectId    String?        @db.Uuid
  outputId     String?        @db.Uuid
  timeEntryId  String?        @db.Uuid
  approvalType String
  status       ApprovalStatus @default(PENDING)
  actorRole    String
  actorId      String?        @db.Uuid
  reason       String?        @db.Text
  decidedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  request      Request?       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  project      Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  output       ProjectOutput? @relation(fields: [outputId], references: [id], onDelete: Cascade)
  timeEntry    TimeEntry?     @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)

  @@index([requestId, status])
  @@index([projectId, status])
  @@index([outputId, status])
  @@index([timeEntryId, status])
  @@map("approvals")
}

model TimeEntry {
  id                 String                  @id @default(uuid()) @db.Uuid
  userId             String                  @db.Uuid
  requestId          String?                 @db.Uuid
  projectId          String?                 @db.Uuid
  outputId           String?                 @db.Uuid
  hours              Decimal                 @db.Decimal(10, 2)
  billable           Boolean                 @default(true)
  deductHours        Boolean                 @default(true)
  status             TimeEntryStatus         @default(DRAFT)
  workDate           DateTime
  notes              String?                 @db.Text
  submittedAt        DateTime?
  decidedAt          DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  user               User                    @relation(fields: [userId], references: [id], onDelete: Restrict)
  request            Request?                @relation(fields: [requestId], references: [id], onDelete: Restrict)
  project            Project?                @relation(fields: [projectId], references: [id], onDelete: Restrict)
  output             ProjectOutput?          @relation(fields: [outputId], references: [id], onDelete: Restrict)
  approvals          Approval[]
  ledgerTransactions HourLedgerTransaction[]

  @@index([userId, status, workDate])
  @@index([requestId])
  @@index([projectId])
  @@map("time_entries")
}

model HourLedgerTransaction {
  id            String                @id @default(uuid()) @db.Uuid
  clientId      String                @db.Uuid
  timeEntryId   String?               @db.Uuid
  type          LedgerTransactionType
  hours         Decimal               @db.Decimal(10, 2)
  balanceBefore Decimal               @db.Decimal(10, 2)
  balanceAfter  Decimal               @db.Decimal(10, 2)
  referenceCode String                @unique
  reason        String?               @db.Text
  createdAt     DateTime              @default(now())
  client        Client                @relation(fields: [clientId], references: [id], onDelete: Restrict)
  timeEntry     TimeEntry?            @relation(fields: [timeEntryId], references: [id], onDelete: Restrict)

  @@index([clientId, createdAt])
  @@map("hour_ledger_transactions")
}

model WorkflowEvent {
  id                String              @id @default(uuid()) @db.Uuid
  workflowVersionId String              @db.Uuid
  transitionId      String?             @db.Uuid
  requestId         String?             @db.Uuid
  projectId         String?             @db.Uuid
  fromStateId       String?             @db.Uuid
  toStateId         String              @db.Uuid
  actorId           String?             @db.Uuid
  actorRole         String
  reason            String?             @db.Text
  metadata          Json?
  occurredAt        DateTime            @default(now())
  workflowVersion   WorkflowVersion     @relation(fields: [workflowVersionId], references: [id], onDelete: Restrict)
  transition        WorkflowTransition? @relation(fields: [transitionId], references: [id], onDelete: SetNull)
  request           Request?            @relation(fields: [requestId], references: [id], onDelete: Cascade)
  project           Project?            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromState         WorkflowState?      @relation("WorkflowEventFromState", fields: [fromStateId], references: [id], onDelete: Restrict)
  toState           WorkflowState       @relation("WorkflowEventToState", fields: [toStateId], references: [id], onDelete: Restrict)

  @@index([requestId, occurredAt])
  @@index([projectId, occurredAt])
  @@map("workflow_events")
}

model Notification {
  id          String             @id @default(uuid()) @db.Uuid
  userId      String             @db.Uuid
  event       String
  targetType  String
  targetId    String
  messageAr   String?            @db.Text
  messageEn   String?            @db.Text
  deepLink    String
  status      NotificationStatus @default(PENDING)
  readAt      DateTime?
  deliveredAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([targetType, targetId])
  @@map("notifications")
}

model AuditLog {
  id         String        @id @default(uuid()) @db.Uuid
  actorId    String?       @db.Uuid
  eventCode  String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  reason     String?       @db.Text
  requestId  String?
  ipAddress  String?
  userAgent  String?       @db.Text
  severity   AuditSeverity
  occurredAt DateTime      @default(now())
  actor      User?         @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, occurredAt])
  @@index([actorId, occurredAt])
  @@index([eventCode, occurredAt])
  @@map("audit_logs")
}

model ImportJob {
  id             String    @id @default(uuid()) @db.Uuid
  type           String
  sourceFileName String
  sourceSha256   String
  status         JobStatus @default(PENDING)
  preview        Json?
  errors         Json?
  appliedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, createdAt])
  @@map("import_jobs")
}

model ExportJob {
  id         String    @id @default(uuid()) @db.Uuid
  type       String
  scope      Json
  status     JobStatus @default(PENDING)
  storageKey String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status, createdAt])
  @@map("export_jobs")
}

model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  occurredAt    DateTime  @default(now())
  availableAt   DateTime  @default(now())
  processedAt   DateTime?
  attemptCount  Int       @default(0)
  lastError     String?   @db.Text

  @@index([processedAt, availableAt])
  @@index([aggregateType, aggregateId])
  @@map("outbox_events")
}
